#!/bin/bash

# ===========================
# ⚙️ ciee - Compile & Run C
# ===========================

# --- Colors ---
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
YELLOW=$'\033[1;33m'
ITALIC=$'\033[3m'
RESET=$'\033[0m'

# --- Flags ---
SILENT=false
COMPILE_ONLY=false
RUN_ONLY=false

# --- Detect OS ---
OS="$(uname -s)"
IS_WINDOWS=false
case "$OS" in
  MINGW*|MSYS*|CYGWIN*)
    IS_WINDOWS=true
    ;;
esac

# --- Spinner ---
spinner() {
  local pid=$1
  local delay=0.1
  local spin='|/-\'
  if [ "$SILENT" = false ]; then
    while kill -0 $pid 2>/dev/null; do
      for i in $(seq 0 3); do
        printf "\r${CYAN}Compiling... ${spin:$i:1}${RESET}"
        sleep $delay
      done
    done
  fi
}

# --- Compile ---
compile() {
  tmp_log=$(mktemp)

  gcc "$FILE" -o "$OUTPUT" "${USER_FLAGS[@]}" >"$tmp_log" 2>&1 &
  local pid=$!

  spinner $pid

  wait $pid
  local status=$?

  if [ $status -ne 0 ]; then
    [ "$SILENT" = false ] && printf "\r${RED}❌ Compilation failed.${RESET}\n\n"
    cat "$tmp_log"
    rm -f "$tmp_log"
    return 1
  fi

  [ "$SILENT" = false ] && printf "\r${GREEN}✅ Compilation successful.${RESET}\n\n"
  rm -f "$tmp_log"
  return 0
}

# --- Run ---
run() {
  [ "$SILENT" = false ] && echo -e "${YELLOW}> Running $OUTPUT...${RESET}\n"

  if [ "$IS_WINDOWS" = true ]; then
    ./"$OUTPUT.exe"
  else
    ./"$OUTPUT"
  fi
}

# --- Parse flags ---
while getopts ":scr" opt; do
  case ${opt} in
    s ) SILENT=true ;;
    c ) COMPILE_ONLY=true ;;
    r ) RUN_ONLY=true ;;
    \? )
      echo -e "${RED}Invalid option: -$OPTARG${RESET}"
      echo -e "Usage: cc [-s] [-c|-r] <file.c> [gcc flags]"
      exit 1
    ;;
  esac
done

# --- Handle combined flags ---
for arg in "$@"; do
  case $arg in
    -cs)
      COMPILE_ONLY=true
      SILENT=true
      ;;
    -rs)
      RUN_ONLY=true
      SILENT=true
      ;;
  esac
done

shift $((OPTIND -1))

# --- Banner ---
if [ "$SILENT" = false ]; then
  echo -e "${YELLOW}"
  echo "╔════════════════════════════════════╗"
  echo "║          😍  cie-ciee  😍          ║"
  echo "╚════════════════════════════════════╝"
  echo -e "${RESET}"
fi

# --- Check file ---
if [ -z "$1" ]; then
  echo -e "${ITALIC}\"Karena gw males gcc + run manual, mending ngegojlokin c😴\"${RESET}"
  echo -e "\n${CYAN}Compile and Run C Program${RESET}"
  echo -e "${YELLOW}Usage:${RESET} ciee [-s] [-c|-r] <file.c> [gcc flags]"
  echo -e "  -s  : Silent mode"
  echo -e "  -c  : Compile only"
  echo -e "  -r  : Run only"
  echo -e "  -cs : Compile only (silent)"
  echo -e "  -rs : Run only (silent)"
  exit 1
fi

FILE="$1"
shift

# Remaining args = gcc flags
USER_FLAGS=("$@")

BASENAME=$(basename "$FILE" .c)
OUTPUT="$BASENAME"

# --- Modes ---
if [[ "$COMPILE_ONLY" = true && "$RUN_ONLY" = false ]]; then
  compile
  exit 0
fi

if [[ "$COMPILE_ONLY" = false && "$RUN_ONLY" = true ]]; then
  run
  exit 0
fi

# --- Default: Compile + Run ---
compile && run