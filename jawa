#!/bin/bash

# ===========================
# ☕ JAWA - Compile & Run Java
# ===========================

# --- Colors ---
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
YELLOW=$'\033[1;33m'
ITALIC=$'\033[3m'
RESET=$'\033[0m'

# --- Flags ---
SILENT=false
COMPILE_ONLY=false
RUN_ONLY=false

# --- Functions ---
spinner() {
  local pid=$1
  local delay=0.1
  local spin='|/-\'
  if [ "$SILENT" = false ]; then
    while kill -0 $pid 2>/dev/null; do
      for i in $(seq 0 3); do
        printf "\r${CYAN}Compiling... ${spin:$i:1}${RESET}"
        sleep $delay
      done
    done
  fi
}

compile() {
	# Capture javac output while spinner runs
  tmp_log=$(mktemp)
  javac "$FILE" >"$tmp_log" 2>&1 &
  local pid=$!

  spinner $pid

  wait $pid
  local status=$?

  if [ $status -ne 0 ]; then
    [ "$SILENT" = false ] && printf "\r${RED}❌ Compilation failed.${RESET}\n\n"
    cat "$tmp_log"
    rm -f "$tmp_log"
    return 1
  fi
  [ "$SILENT" = false ] && printf "\r${GREEN}✅ Compilation successful.${RESET}\n\n"
  rm -f "$tmp_log"
  return 0
}

run() {
  [ "$SILENT" = false ] && echo -e "${YELLOW}> Running $BASENAME...${RESET}\n"
  java "$BASENAME"
}

while getopts ":scr" opt; do
  case ${opt} in
    s ) SILENT=true ;;
    c ) COMPILE_ONLY=true ;;
    r ) RUN_ONLY=true ;;
    \? )
      echo -e "${RED}Invalid option: -$OPTARG${RESET}"
      echo -e "Usage: jawa [-s] [-c|-r] <filename.java>"
      exit 1
    ;;
  esac
done

# --- Handle compound flags (-cs, -rs) ---
for arg in "$@"; do
  case $arg in
    -cs)
      COMPILE_ONLY=true
      SILENT=true
      ;;
    -rs)
      RUN_ONLY=true
      SILENT=true
      ;;
  esac
done

shift $((OPTIND -1))

# --- Banner ---
if [ "$SILENT" = false ]; then
  echo -e "${YELLOW}"
  echo "╔════════════════════════════════════╗"
  echo "║        ☕ JAWA, JAWA, JAWA! ☕     ║"
  echo "╚════════════════════════════════════╝"
  echo -e "${RESET}"
fi

# --- Argument check ---
if [ -z "$1" ]; then
  echo -e "${ITALIC}\"Karena gw males run javac + java, mending run jawa;p\"${RESET}"
  echo -e "\n${CYAN}Compile and Run Java Program${RESET}"
  echo -e "${YELLOW}Usage:${RESET} jawa [-s] [-c|-r] <filename.java>"
  echo -e "  -s : Silent mode (no banner or messages)"
  echo -e "  -c : Compile only"
  echo -e "  -r : Run only"
  echo -e "  -cs : Compile only (silent)"
  echo -e "  -rs : Run only (silent)"
  exit 1
fi

FILE="$1"
BASENAME=$(basename "$FILE" .java)

# --- Compile only mode ---
if [[ "$COMPILE_ONLY" = true && "$RUN_ONLY" = false ]]; then
  compile
  exit 1
fi

# --- Run only mode ---
if [[ "$COMPILE_ONLY" = false && "$RUN_ONLY" = true ]]; then
  run
  exit 1
fi

# --- Compile + Run ---
if [[ "$RUN_ONLY" = "$COMPILE_ONLY" ]]; then
  compile && run
  exit 1
fi
